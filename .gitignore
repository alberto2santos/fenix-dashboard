# ============================================================
# .gitignore — Fênix II Dashboard
# ============================================================

# ─── Dependências ────────────────────────────────────────────
node_modules/
.pnp
.pnp.js

# ─── Build ───────────────────────────────────────────────────
dist/
dist-ssr/
build/

# ─── Cache Vite / TypeScript ──────────────────────────────────
.vite/
*.tsbuildinfo
tsconfig.tsbuildinfo

# ─── Cache TanStack Query (localStorage não vai pro git,
#     mas se usar persistência em arquivo sim) ─────────────────
.query-cache/

# ─── Variáveis de ambiente ───────────────────────────────────
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env.*.local

# ─── Logs ────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ─── Editores ────────────────────────────────────────────────
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
!.vscode/launch.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.swp

# ─── Sistema operacional ─────────────────────────────────────
.DS_Store
.DS_Store?
Thumbs.db
ehthumbs.db
Desktop.ini

# ─── Testes / Coverage ───────────────────────────────────────
coverage/
playwright-report/
test-results/
.playwright/

# ─── Bundle analyzer ─────────────────────────────────────────
stats.html

# ─── CSV de dados reais (nunca versionar dados da empresa) ────
*.csv
!public/*.csv