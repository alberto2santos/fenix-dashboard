{
  "name": "fenix-dashboard",
  "private": true,
  "version": "1.0.0",
  "author": {
    "name": "Alberto Luiz",
    "email": "alberto.dos.santos93@gmail.com",
    "url": "https://github.com/alberto2santos"
  },
  "description": "Dashboard de monitoramento de soldagem — Projeto Fênix II",
  "type": "module",
  "keywords": [
    "dashboard",
    "monitoramento",
    "soldagem",
    "projeto-fenix-ii"
  ],

  "engines": {
    "node": ">=20 <25"
  },

  "browserslist": {
    "production": [
      "last 2 Chrome versions",
      "last 2 Edge versions"
    ],
    "development": [
      "last 1 Chrome version"
    ]
  },

  "scripts": {
    "dev":        "vite",
    "build":      "tsc && vite build",
    "preview":    "vite preview",
    "server":     "node server/export.js",
    "lint":       "eslint src --max-warnings 0",
    "type-check": "tsc --noEmit",
    "analyze":    "ANALYZE=true npm run build",
    "audit":      "npm audit --audit-level=high"
  },

  "dependencies": {
    "@tanstack/query-async-storage-persister": "^5.90.24",
    "@tanstack/react-query":                  "^5.90.21",
    "@tanstack/react-query-persist-client":   "^5.90.24",
    "clsx":                                   "^2.1.1",
    "echarts":                                "^5.5.1",
    "echarts-for-react":                      "^3.0.2",
    "lucide-react":                           "^0.475.0",
    "papaparse":                              "^5.4.1",
    "react":                                  "^19.2.0",
    "react-dom":                              "^19.2.0",
    "tailwind-merge":                         "^2.6.0",
    "zod":                                    "^3.24.0"
  },

  "devDependencies": {
    "@eslint/js":                  "^9.39.1",
    "@types/node":                 "^24.10.1",
    "@types/papaparse":            "^5.3.14",
    "@types/react":                "^19.2.7",
    "@types/react-dom":            "^19.2.3",
    "@vitejs/plugin-react-swc":    "^3.8.0",
    "autoprefixer":                "^10.4.20",
    "eslint":                      "^9.39.1",
    "eslint-plugin-react-hooks":   "^5.2.0",
    "eslint-plugin-react-refresh":  "^0.4.19",
    "globals":                     "^16.5.0",
    "playwright":                  "^1.50.0",
    "postcss":                     "^8.5.3",
    "rollup-plugin-visualizer":    "^5.12.0",
    "tailwindcss":                 "^3.4.17",
    "typescript":                  "~5.9.3",
    "typescript-eslint":           "^8.48.0",
    "vite":                        "^6.2.0"
  }
}